# -----------------------------------------------------------------------------
# Supabase (PostgreSQL Database)
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → Database
#
# For Prisma: use the "Connection string" → "URI" (Direct connection, port 5432)
# Add ?schema=public to the end if needed for Prisma
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?schema=public"

# -----------------------------------------------------------------------------
# Supabase (Client SDK - optional, for Storage/Realtime)
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# -----------------------------------------------------------------------------
# Auth (NextAuth.js - keep existing)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# AI (OpenAI / Minimax)
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-your-key-here"
MINIMAX_API_KEY="your-minimax-key-here"

# -----------------------------------------------------------------------------
# AWS Bedrock (lease legal + compliance agents – optional, improves credibility evaluation)
# -----------------------------------------------------------------------------
# Enable to use Claude for lease review and HK regulatory compliance assessment.
# See: https://aws.amazon.com/blogs/machine-learning/build-an-intelligent-contract-management-solution-with-amazon-quick-suite-and-bedrock-agentcore/
# -----------------------------------------------------------------------------
BEDROCK_LEASE_REVIEW_ENABLED="false"
BEDROCK_RISK_ASSESSMENT_ENABLED="false"
AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# BEDROCK_MODEL_ID="anthropic.claude-3-5-sonnet-v2:0"
