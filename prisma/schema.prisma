generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String?
  hashedPassword String
  businessType   String?
  businessDesc   String?
  preferences    Json?
  onboarded      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  shortlists     Shortlist[]
  interactions   UserInteraction[]
}

model Property {
  id                String          @id @default(cuid())
  canonicalId       String          @unique
  title             String
  titleZh           String?
  description       String
  descriptionZh     String?
  district          String
  address           String
  propertyType      String
  saleableArea      Float?
  grossArea         Float?
  monthlyRent       Float?
  psfRent           Float?
  managementFee     Float?
  price             Float?
  floor             String?
  images            String[]
  floorPlanUrl      String?
  latitude          Float?
  longitude         Float?
  verificationScore Float           @default(0)
  status            String          @default("active")
  engagementScore   Int             @default(0)
  features          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sourceListings    SourceListing[]
  evidencePack      EvidencePack?
  riskChecks        RiskCheck[]
  shortlists        Shortlist[]
  interactions      UserInteraction[]
}

model SourceListing {
  id           String   @id @default(cuid())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  source       String
  sourceUrl    String?
  rawData      Json
  agentName    String?
  agentContact String?
  scrapedAt    DateTime
  createdAt    DateTime @default(now())
}

model EvidencePack {
  id                   String   @id @default(cuid())
  propertyId           String   @unique
  property             Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownershipStatus      String   @default("unconfirmed")
  ownershipSource      String?
  ownershipDate        DateTime?
  floorPlanStatus      String   @default("unconfirmed")
  floorPlanSource      String?
  buildingRecordStatus String   @default("unconfirmed")
  buildingRecordSource String?
  tenancyStatus        String   @default("unconfirmed")
  tenancyDetail        String?
  ubwStatus            String   @default("unconfirmed")
  ubwDetail            String?
  completionPct        Float    @default(0)
  updatedAt            DateTime @updatedAt
}

model RiskCheck {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sectorType     String
  checkName      String
  status         String
  confidence     Float
  explanation    String
  recommendation String
  sources        String[]
  createdAt      DateTime @default(now())

  @@unique([propertyId, sectorType, checkName])
}

model Shortlist {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
}

model UserInteraction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  action     String
  metadata   Json?
  createdAt  DateTime  @default(now())
}
